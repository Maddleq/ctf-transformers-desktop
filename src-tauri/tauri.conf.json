{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CTF Transformers",
  "version": "0.2.0",
  "identifier": "com.ctf.transformers",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CTF Transformers — Информация по игре",
        "width": 760,
        "height": 920,
        "minWidth": 380,
        "minHeight": 500,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
